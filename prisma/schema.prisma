generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                @id @default(autoincrement())
  email              String             @unique
  password           String
  role               Role               @default(TENANT)
  name               String?
  uniqueNumber       String?            @unique
  schoolName         String?
  hostelName         String?
  roomNumber         String?
  location           String?
  isVerified         Boolean            @default(false)
  phone              String?
  businessName       String?
  gpsAddress         String?
  ghanaCard          String?
  legalDocs          String?
  verificationStatus String             @default("NONE")
  verificationNotes  String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  bookings           Booking[]
  hostels            Hostel[]
  verification       OwnerVerification?

  @@map("user")
}

model OwnerVerification {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  ownerPhoto      String?  @db.LongText
  idCardPhoto     String?  @db.LongText
  facilitiesPhoto String?  @db.LongText
  utilities       String?  @db.LongText
  roomSize        String?  @db.LongText
  verifiedPrices  String?  @db.LongText
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("owner_verification")
}

model Hostel {
  id           Int         @id @default(autoincrement())
  name         String
  description  String?     @db.LongText
  location     String
  price        Float
  images       String?     @db.LongText
  createdAt    DateTime    @default(now())
  ownerId      Int
  universityId Int?
  gender           String      @default("MIXED")
  totalRooms       Int         @default(10)
  capacityPerRoom  Int         @default(4)
  bookings         Booking[]
  owner        User        @relation(fields: [ownerId], references: [id])
  university   University? @relation(fields: [universityId], references: [id])

  @@index([ownerId], map: "hostel_ownerId_fkey")
  @@index([universityId], map: "hostel_universityId_fkey")
  @@map("hostel")
}

model University {
  id       Int      @id @default(autoincrement())
  name     String   @unique
  location String?
  hostels  Hostel[]

  @@map("university")
}

model Booking {
  id             Int       @id @default(autoincrement())
  studentId      Int
  hostelId       Int
  amount         Float
  paymentPhone   String?
  telecom        String?
  verificationId String?   @unique
  status         String    @default("APPLIED")
  createdAt      DateTime  @default(now())
  durationMonths Int?
  expiresAt      DateTime?
  hostel         Hostel    @relation(fields: [hostelId], references: [id])
  student        User      @relation(fields: [studentId], references: [id])

  @@index([hostelId], map: "booking_hostelId_fkey")
  @@index([studentId], map: "booking_studentId_fkey")
  @@map("booking")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  OWNER
  TENANT
}
